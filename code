import os 
from dotenv import load_dotenv
from langchain_groq import ChatGroq
load_dotenv()
  
GROQ_API_KEY=os.getenv("GROQ_API_KEY")
model=ChatGroq(
    groq_api_key=GROQ_API_KEY,
    model_name="llama-3.1-8b-instant"
)
print(GROQ_API_KEY)

from langchain_core.messages import HumanMessage
model.invoke([HumanMessage(content="hi, my name is jinam and i will become gen ai engineer")])


#list of messages -->> able to remember the conversation/chat history here
